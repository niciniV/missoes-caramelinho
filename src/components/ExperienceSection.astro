---
import { ASSETS, PREVISTO, TRILHA } from "../config/site";
import Icon from "./Icon.astro";
---

<section class="secao experiencia" id="experiencia" aria-labelledby="titulo-experiencia">
  <div class="container">
    <div class="cabecalho-secao">
      <span class="kicker laranja"><Icon name="patinha" size={15} /> A experiência</span>
      <h2 class="titulo-secao" id="titulo-experiencia">
        Um dia inteiro de aprendizado, casa por casa
      </h2>
      <p class="subtitulo-secao">
        A experiência educativa digital do {`PSE Nova Santa Rita`} está sendo preparada no formato de
        um jogo de tabuleiro: o percurso acompanha um dia na vida escolar, da saída de casa até o retorno
        — com desafios, escolhas e estrelinhas de incentivo pelo caminho.
      </p>
    </div>

    <div class="experiencia-grade">
      <!-- Trilha do tabuleiro -->
      <ol class="trilha" aria-label="Trechos do percurso previsto">
        {
          TRILHA.map((passo, i) => (
            <li class="casa" style={`--i:${i}`}>
              <span class="casa-numero" aria-hidden="true">
                {i + 1}
              </span>
              <div>
                <h3>{passo.titulo}</h3>
                <p>{passo.texto}</p>
              </div>
            </li>
          ))
        }
      </ol>

      <!-- Arte conceitual + previsto -->
      <div class="experiencia-lado">
        <figure class="arte-conceitual" data-mascot-curtain="paper-in">
          <img
            src={ASSETS.arteConceitual}
            alt="Arte conceitual do jogo de tabuleiro em desenvolvimento: um caminho de casas numeradas entre a casa e a escola, com o Caramelinho no início do percurso"
            width="900"
            height="1014"
            loading="lazy"
            decoding="async"
          />
          <figcaption>
            <Icon name="brilho" size={14} />
            Arte conceitual — o jogo está em desenvolvimento.
          </figcaption>
        </figure>

        <div class="previsto" data-mascot-curtain="paper-out">
          <h3>O que está previsto</h3>
          <ul>
            {
              PREVISTO.map((item) => (
                <li>
                  <Icon name="check" size={17} />
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>
          <p class="previsto-nota">
            Nenhuma funcionalidade está disponível ainda: esta página será atualizada quando a
            experiência estiver pronta para as escolas.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .experiencia {
    background: var(--papel);
    overflow: clip;
  }

  .experiencia-grade {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(2rem, 4vw, 3.5rem);
    align-items: start;
  }

  /* --- Trilha --- */
  .trilha {
    list-style: none;
    padding: 0;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  /* Caminho pontilhado ligando as casas */
  .trilha::before {
    content: "";
    position: absolute;
    left: 1.55rem;
    top: 1.4rem;
    bottom: 1.4rem;
    border-left: 3px dashed rgb(61 155 78 / 0.45);
  }

  .casa {
    position: relative;
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    background: var(--nuvem);
    border: 1.5px solid var(--linha);
    border-radius: var(--raio-m);
    padding: 1.1rem 1.2rem 1.1rem 0.9rem;
    box-shadow: var(--sombra-card);
  }

  /* Zig-zag suave, como as casas de um tabuleiro */
  .casa:nth-child(even) {
    margin-left: clamp(0rem, 4vw, 2.6rem);
  }

  .casa-numero {
    flex: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 50%;
    font-weight: 900;
    font-size: 1.05rem;
    color: #fff;
    box-shadow: inset 0 -3px 0 rgb(0 0 0 / 0.18);
  }

  .casa:nth-child(6n + 1) .casa-numero {
    background: var(--verde);
  }
  .casa:nth-child(6n + 2) .casa-numero {
    background: var(--laranja);
  }
  .casa:nth-child(6n + 3) .casa-numero {
    background: var(--azul);
  }
  .casa:nth-child(6n + 4) .casa-numero {
    background: var(--amarelo);
    color: var(--tinta);
  }
  .casa:nth-child(6n + 5) .casa-numero {
    background: var(--agua);
  }
  .casa:nth-child(6n + 6) .casa-numero {
    background: var(--roxo);
  }

  .casa h3 {
    font-size: 1.08rem;
  }

  .casa p {
    margin-top: 0.25rem;
    font-size: 0.92rem;
    color: var(--tinta-suave);
  }

  /* --- Lado direito --- */
  .experiencia-lado {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .arte-conceitual {
    border-radius: var(--raio-l);
    overflow: hidden;
    border: 1.5px solid var(--linha);
    background: var(--nuvem);
    box-shadow: var(--sombra-card);
  }

  .arte-conceitual img {
    width: 100%;
    height: auto;
    aspect-ratio: 900 / 1014;
    object-fit: cover;
  }

  .arte-conceitual figcaption {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.75rem 1.1rem;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--amarelo-escuro);
    background: var(--amarelo-claro);
  }

  .previsto {
    background: var(--azul-claro);
    border: 1.5px solid rgb(46 111 183 / 0.25);
    border-radius: var(--raio-l);
    padding: 1.5rem 1.5rem 1.3rem;
  }

  .previsto h3 {
    font-size: 1.2rem;
    color: var(--azul-escuro);
  }

  .previsto ul {
    list-style: none;
    padding: 0;
    margin-top: 0.9rem;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .previsto li {
    display: flex;
    gap: 0.6rem;
    align-items: flex-start;
    font-size: 0.95rem;
    color: var(--tinta);
  }

  .previsto li svg {
    flex: none;
    margin-top: 0.2rem;
    color: var(--verde);
  }

  .previsto-nota {
    margin-top: 1rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--azul-escuro);
    border-top: 1.5px dashed rgb(46 111 183 / 0.35);
    padding-top: 0.9rem;
  }

  @media (max-width: 56rem) {
    .experiencia-grade {
      grid-template-columns: 1fr;
    }
    .arte-conceitual {
      max-width: 26rem;
      margin-inline: auto;
    }
  }
</style>
